    margin-bottom: var(--ostk-space-4);
  }

  .card h3 {
    margin-top: 0;
    font-size: var(--ostk-text-md);
    margin-bottom: var(--ostk-space-3);
  }

  .card p {
    margin-bottom: 0;
  }

  .card:hover {
    border-color: var(--ostk-border-default);
  }

  .cta {
    margin-top: var(--ostk-space-8);
    color: var(--ostk-text-muted);
  }
</style>
