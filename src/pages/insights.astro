---
import Base from '../layouts/Base.astro';
---

<Base title="Insights — ostk" description="Proofs of your os + tack. Discovered, measured, compounded.">
  <div class="container">
    <h1>Insights</h1>

    <p>All insights live at <a href="https://needle-bench.cc/insights">needle-bench.cc/insights</a> — proofs of your os + tack, compounded across sessions.</p>

    <div class="links">
      <a href="https://needle-bench.cc/insights" class="primary-link">View insights →</a>
      <a href="https://needle-bench.cc/leaderboard" class="secondary-link">Leaderboard →</a>
    </div>
  </div>
</Base>

<style>
  .links {
    display: flex;
    gap: var(--ostk-space-4);
    margin-top: var(--ostk-space-6);
  }

  .primary-link {
    font-family: var(--ostk-font-mono);
    color: var(--ostk-needle);
    font-size: var(--ostk-text-md);
  }

  .secondary-link {
    font-family: var(--ostk-font-mono);
    color: var(--ostk-text-secondary);
    font-size: var(--ostk-text-md);
  }
</style>
