---
import Base from '../layouts/Base.astro';
import PillarCard from '../components/PillarCard.astro';
import InstallSnippet from '../components/InstallSnippet.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Base title="ostk — the invisible OS for AI coding agents" description="A local-first OS for AI coding agents. Invisible coordination, GPG-signed audit trail, conflict resolution. Free and open source.">
  <div class="container">

    <section class="hero">
      <h1 class="hero-value">Your AI agents run on an OS. ostk is that OS.</h1>
      <p class="hero-sub">Local-first. GPG-signed. Audited. Yours.</p>

      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-body">
          <div class="terminal-line"><span class="prompt">$</span> curl -fsSL https://ostk.ai/install | sh</div>
          <div class="terminal-line"><span class="prompt">$</span> cd ~/projects/my-repo</div>
          <div class="terminal-line"><span class="prompt">$</span> ostk init --guided</div>
          <div class="terminal-blank"></div>
          <div class="terminal-line"><span class="prompt">$</span> ostk boot</div>
        </div>
      </div>

      <div class="hero-actions">
        <a href="/docs/getting-started" class="btn-primary">Get Started</a>
        <a href="#pillars" class="btn-secondary">How it works</a>
      </div>
    </section>

    <section id="pillars" class="pillars">
      <h2 class="section-label">What it does</h2>
      <div class="pillars-list">
        <PillarCard
          number={1}
          title="Invisible Write Path"
          description="Agents edit files normally. The OS intercepts, coordinates, and audits underneath. They never know."
          href="/features/invisible-writes"
        />
        <PillarCard
          number={2}
          title="Multi-Agent Coordination"
          description="Multiple agents, one codebase. Conflicts resolved at write time. No locks, no message buses."
          href="/features/coordination"
        />
        <PillarCard
          number={3}
          title="Audit Trail"
          description="Every edit tracked, cryptographically signed, append-only. You know who changed what and when."
          href="/features/audit-trail"
        />
        <PillarCard
          number={4}
          title="Context Injection"
          description="Agents skip exploration. The OS front-loads project context so the first turn is productive."
          href="/features/context-injection"
        />
        <PillarCard
          number={5}
          title="Local-First"
          description="No cloud. No telemetry. A single Rust binary on your machine. Works with local models."
          href="/features/local-first"
        />
      </div>
    </section>

    <section class="how-it-works">
      <h2>How it works</h2>
      <ol class="steps">
        <li>
          <strong>Install.</strong>
          <code>curl -fsSL https://ostk.ai/install | sh</code> — then <code>ostk init</code> in any git repo.
        </li>
        <li>
          <strong>Work.</strong>
          Your agents use their normal tools. The OS intercepts writes, resolves conflicts, and tracks every edit. Nothing changes for the agent.
        </li>
        <li>
          <strong>Compound.</strong>
          The OS learns your project's vocabulary across sessions. Communication compresses. Repeated patterns resolve faster. Later sessions start where earlier sessions left off.
        </li>
      </ol>
    </section>

    <section class="tui-preview">
      <h2>See it working</h2>
      <figure class="tui-figure">
        <img src="/images/tui/tui-agent-workflow.jpg" alt="TUI showing an agent executing work items with real-time status bar showing model, context usage, and cost" class="tui-screenshot" />
        <figcaption>The TUI shows the OS in real time — agents executing work, file edits resolving, permissions gating. <a href="/features/tui">Learn more.</a></figcaption>
      </figure>
    </section>

    <CTABanner />
  </div>
</Base>

<style>
  .hero {
    padding-top: var(--ostk-space-8);
    padding-bottom: var(--ostk-space-8);
  }

  .hero-value {
    font-size: var(--ostk-text-2xl);
    font-weight: var(--ostk-weight-bold);
    color: var(--ostk-text-primary);
    line-height: var(--ostk-leading-tight);
    letter-spacing: var(--ostk-tracking-tight);
    margin-bottom: var(--ostk-space-2);
  }

  .hero-sub {
    font-size: var(--ostk-text-md);
    color: var(--ostk-text-secondary);
    margin-bottom: var(--ostk-space-6);
  }

  .terminal {
    background: var(--ostk-bg-raised);
    border: 1px solid var(--ostk-border-subtle);
    border-radius: var(--ostk-radius-md);
    overflow: hidden;
    margin-bottom: var(--ostk-space-6);
  }

  .terminal-bar {
    height: 2rem;
    background: var(--ostk-bg-elevated);
    display: flex;
    align-items: center;
    padding: 0 var(--ostk-space-3);
    gap: var(--ostk-space-2);
  }

  .terminal-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ostk-text-ghost);
  }

  .terminal-body {
    padding: var(--ostk-space-6);
    font-family: var(--ostk-font-mono);
  }

  .terminal-line {
    line-height: 1.8;
    font-size: var(--ostk-text-sm);
  }

  .terminal-blank {
    height: var(--ostk-space-4);
  }

  .prompt {
    color: var(--ostk-text-muted);
    margin-right: var(--ostk-space-2);
  }

  .hero-actions {
    display: flex;
    gap: var(--ostk-space-3);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    padding: var(--ostk-space-2) var(--ostk-space-6);
    background: var(--ostk-needle);
    color: var(--ostk-bg-deep);
    border-radius: var(--ostk-radius-md);
    font-weight: var(--ostk-weight-bold);
    font-size: var(--ostk-text-sm);
    text-decoration: none;
    transition: background var(--ostk-duration-fast) var(--ostk-easing);
  }

  .btn-primary:hover {
    background: var(--ostk-needle-bright);
    color: var(--ostk-bg-deep);
  }

  .btn-secondary {
    display: inline-block;
    padding: var(--ostk-space-2) var(--ostk-space-6);
    border: 1px solid var(--ostk-border-default);
    color: var(--ostk-text-secondary);
    border-radius: var(--ostk-radius-md);
    font-weight: var(--ostk-weight-medium);
    font-size: var(--ostk-text-sm);
    text-decoration: none;
    transition: border-color var(--ostk-duration-fast) var(--ostk-easing),
                color var(--ostk-duration-fast) var(--ostk-easing);
  }

  .btn-secondary:hover {
    border-color: var(--ostk-needle-dim);
    color: var(--ostk-text-primary);
  }

  .section-label {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-xs);
    text-transform: uppercase;
    letter-spacing: var(--ostk-tracking-wide);
    color: var(--ostk-text-muted);
    margin-bottom: var(--ostk-space-3);
    margin-top: 0;
  }

  .pillars {
    margin-bottom: var(--ostk-space-12);
  }

  .pillars-list {
    display: flex;
    flex-direction: column;
    gap: var(--ostk-space-3);
  }

  .how-it-works {
    margin-bottom: var(--ostk-space-12);
  }

  .steps {
    padding-left: var(--ostk-space-6);
  }

  .steps li {
    margin-bottom: var(--ostk-space-4);
    line-height: var(--ostk-leading-relaxed);
  }

  .steps code {
    background: var(--ostk-bg-raised);
    padding: 0.15em 0.4em;
    border-radius: var(--ostk-radius-sm);
    font-size: 0.9em;
  }

  .tui-preview {
    margin-bottom: var(--ostk-space-12);
  }

  .tui-figure {
    margin: 0;
    border: 1px solid var(--ostk-border-subtle);
    border-radius: var(--ostk-radius-md);
    overflow: hidden;
  }

  .tui-screenshot {
    width: 100%;
    display: block;
  }

  .tui-figure figcaption {
    padding: var(--ostk-space-3) var(--ostk-space-4);
    font-size: var(--ostk-text-sm);
    color: var(--ostk-text-muted);
    border-top: 1px solid var(--ostk-border-subtle);
    line-height: var(--ostk-leading-normal);
  }

</style>
