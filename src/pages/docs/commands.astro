    margin: 0.25rem 0;
    color: var(--ostk-text-muted, #8b949e);
    font-size: var(--ostk-text-sm, 0.875rem);
  }
  .cmd-ref pre {
    background: var(--ostk-bg-raised, #161b22);
    border: 1px solid var(--ostk-border-subtle, #2a2a2a);
    border-radius: var(--ostk-radius-sm, 4px);
    padding: 0.5rem 0.75rem;
    margin: 0.4rem 0 0;
    overflow-x: auto;
    font-family: var(--ostk-font-mono, monospace);
    font-size: var(--ostk-text-sm, 0.875rem);
    line-height: 1.5;
  }
</style>
