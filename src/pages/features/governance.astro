<FeaturePage
  title="GPG Web of Trust"
  tagline="Trust & Governance"
  description="Identity is cryptographic. Trust tiers from T0 (operator) to T3 (anonymous) determine what each entity can do. Capability pins enforce invisible boundaries."
  relatedPages={[
    { title: "Audit Trail", description: "Every edit tracked and signed", href: "/features/audit-trail" },
    { title: "Secret Management", description: "Keys never enter LLM context", href: "/features/secret-management" },
    { title: "HUMANFILE Reference", description: "Operator identity document", href: "/docs/humanfile" },
