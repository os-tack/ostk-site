---
import NavDropdown from '../components/NavDropdown.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ostk — the invisible OS for AI coding agents' } = Astro.props;
const currentPath = Astro.url.pathname;

function buildBreadcrumbs(path: string) {
  const segments = path.split('/').filter(Boolean);
  if (segments.length === 0) return null;

  const labels: Record<string, string> = {
    features: 'Features',
    docs: 'Docs',
    insights: 'Insights',
    legal: 'Legal',
  };

  const items = [{ name: 'Home', url: 'https://ostk.ai/' }];
  let currentPath = '';

  for (let i = 0; i < segments.length; i++) {
    currentPath += '/' + segments[i];
    const name = labels[segments[i]] || segments[i].split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    items.push({ name, url: `https://ostk.ai${currentPath}/` });
  }

  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": items.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.name,
      "item": item.url
    }))
  };
}

const breadcrumbs = buildBreadcrumbs(currentPath);

const featuresItems = [
  { href: '/features/context-injection', label: 'Context Injection' },
  { href: '/features/coordination', label: 'Multi-Agent' },
  { href: '/features/invisible-writes', label: 'Invisible Writes' },
  { href: '/features/audit-trail', label: 'Audit Trail' },
  { href: '/features/tack', label: 'Tack Language' },
  { href: '/features/local-first', label: 'Local-First' },
  { href: '/features/governance', label: 'Governance' },
  { href: '/features/model-switching', label: 'Model Switching' },
  { href: '/features/secret-management', label: 'Secrets' },
  { href: '/features/tui', label: 'TUI' },
];

const docsItems = [
  { href: '/docs/getting-started', label: 'Quick Start' },
  { href: '/docs/commands', label: 'Commands' },
  { href: '/docs/architecture', label: 'Architecture' },
  { href: '/docs/five-laws', label: 'Five Laws' },
  { href: '/docs/humanfile', label: 'HUMANFILE' },
  { href: '/docs/agentfile', label: 'Agentfile' },
  { href: '/docs/downloads', label: 'Downloads' },
];

const directLinks = [
  { href: '/insights', label: 'Insights' },
  { href: 'https://needle-bench.cc', label: 'Bench', external: true },
  { href: '/about', label: 'About' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Canonical -->
  <link rel="canonical" href={`https://ostk.ai${currentPath}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://ostk.ai${currentPath}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://ostk.ai/og-image.png" />
  <meta property="og:site_name" content="ostk" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://ostk.ai/og-image.png" />

  <!-- JSON-LD: Software Application -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ostk",
    "applicationCategory": "DeveloperApplication",
    "description": "The local-first OS for AI agents. Signed, audited, yours.",
    "url": "https://ostk.ai",
    "operatingSystem": "macOS, Linux",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "downloadUrl": "https://github.com/os-tack/ostk.ai/releases",
    "codeRepository": "https://github.com/os-tack/ostk.ai"
  })} />
  {breadcrumbs && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
  )}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <!-- Plausible Analytics — privacy-first, no cookies -->
  <!-- Plausible Analytics — tagged-events variant supports data-analytics attributes + onclick -->
  <script defer data-domain="ostk.ai" src="https://plausible.io/js/script.tagged-events.outbound-links.js"></script>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-os">os</span><span class="logo-diamond">&#9670;</span><span class="logo-tk">tk</span>
      </a>
      <div class="nav-links">
        <NavDropdown label="Features" items={featuresItems} currentPath={currentPath} />
        <NavDropdown label="Docs" items={docsItems} currentPath={currentPath} />
        {directLinks.map(link => (
          link.external ? (
            <a href={link.href} class="nav-link" target="_blank" rel="noopener noreferrer">
              {link.label}<span class="external-icon">↗</span>
            </a>
          ) : (
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
            >
              {link.label}
            </a>
          )
        ))}
        <div class="nav-social">
          <a href="https://github.com/os-tack" class="nav-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://discord.gg/MdRNs4CC" class="nav-link" target="_blank" rel="noopener noreferrer" aria-label="Discord">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main class="page-content">
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-columns">
        <div class="footer-col">
          <h4 class="footer-col-title">Features</h4>
          <a href="/features/context-injection">Context Injection</a>
          <a href="/features/coordination">Multi-Agent</a>
          <a href="/features/invisible-writes">Invisible Writes</a>
          <a href="/features/audit-trail">Audit Trail</a>
          <a href="/features/tack">Tack Language</a>
          <a href="/features/local-first">Local-First</a>
          <a href="/features/governance">Governance</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Docs</h4>
          <a href="/docs/getting-started">Quick Start</a>
          <a href="/docs/commands">Commands</a>
          <a href="/docs/humanfile">HUMANFILE</a>
          <a href="/docs/agentfile">Agentfile</a>
          <a href="/docs/downloads">Downloads</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Insights</h4>
          <a href="/insights/context-injection">Context Injection</a>
          <a href="/insights/claude-code-source">Claude Code Source</a>
          <a href="/insights/compounding">Compounding</a>
          <a href="/insights/local-first">Local-First</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Meta</h4>
          <a href="/about">About</a>
          <a href="/security">Security</a>
          <a href="/legal/terms">Terms</a>
          <a href="/legal/privacy">Privacy</a>
          <a href="/legal/license">License</a>
          <div class="footer-social">
            <a href="https://github.com/os-tack" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            </a>
            <a href="https://discord.gg/MdRNs4CC" target="_blank" rel="noopener noreferrer" aria-label="Discord">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
            </a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="logo-os">os</span><span class="logo-diamond">&#9670;</span><span class="logo-tk">tk</span>
        <span class="footer-tagline">the invisible os</span>
      </div>
    </div>
  </footer>

  <script>
    // Auto-generate heading IDs and anchor links for h2/h3
    document.querySelectorAll('h2, h3').forEach(heading => {
      if (heading.closest('.footer, nav')) return;
      if (heading.id) return;
      const slug = heading.textContent
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');
      if (!slug) return;
      heading.id = slug;
      const anchor = document.createElement('a');
      anchor.href = `#${slug}`;
      anchor.className = 'heading-anchor';
      anchor.setAttribute('aria-label', `Link to ${heading.textContent.trim()}`);
      anchor.textContent = '#';
      heading.appendChild(anchor);
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .nav {
    background: var(--ostk-bg-base);
    border-bottom: 1px solid var(--ostk-border-subtle);
    position: sticky;
    top: 0;
    z-index: var(--ostk-z-sticky);
  }

  .nav-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 var(--ostk-space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .nav-logo {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-md);
    font-weight: var(--ostk-weight-bold);
    text-decoration: none;
    color: var(--ostk-text-primary);
  }

  .logo-os, .logo-tk {
    color: var(--ostk-text-primary);
  }

  .logo-diamond {
    color: var(--ostk-needle);
  }

  .nav-links {
    display: flex;
    gap: var(--ostk-space-6);
  }

  .nav-link {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-xs);
    color: var(--ostk-text-secondary);
    text-decoration: none;
    padding: var(--ostk-space-1) 0;
  }

  .nav-link:hover {
    color: var(--ostk-text-primary);
  }

  .nav-link.active {
    color: var(--ostk-text-primary);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .external-icon {
    font-size: 0.7em;
    margin-left: 0.2em;
    opacity: 0.6;
  }

  .nav-social {
    display: flex;
    align-items: center;
    gap: var(--ostk-space-3);
    margin-left: var(--ostk-space-2);
  }

  .nav-social .nav-link {
    display: flex;
    align-items: center;
    padding: var(--ostk-space-1);
  }

  .footer-social {
    display: flex;
    gap: var(--ostk-space-3);
    align-items: center;
    margin-top: var(--ostk-space-3);
  }

  .footer-social a {
    color: var(--ostk-text-secondary);
    transition: color var(--ostk-duration-fast) var(--ostk-easing);
  }

  .footer-social a:hover {
    color: var(--ostk-text-primary);
  }

  .footer {
    border-top: 1px solid var(--ostk-border-subtle);
    padding: var(--ostk-space-12) 0 var(--ostk-space-8);
    margin-top: auto;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--ostk-space-8);
    margin-bottom: var(--ostk-space-8);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--ostk-space-2);
  }

  .footer-col-title {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-xs);
    text-transform: uppercase;
    letter-spacing: var(--ostk-tracking-wide);
    color: var(--ostk-text-muted);
    margin-bottom: var(--ostk-space-2);
  }

  .footer-col a {
    font-size: var(--ostk-text-sm);
    color: var(--ostk-text-secondary);
    text-decoration: none;
    transition: color var(--ostk-duration-fast) var(--ostk-easing);
  }

  .footer-col a:hover {
    color: var(--ostk-text-primary);
  }

  .footer-bottom {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-sm);
    font-weight: var(--ostk-weight-bold);
    border-top: 1px solid var(--ostk-border-subtle);
    padding-top: var(--ostk-space-6);
  }

  .footer-tagline {
    color: var(--ostk-text-muted);
    font-weight: var(--ostk-weight-normal);
    margin-left: var(--ostk-space-3);
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: var(--ostk-space-3);
    }

    .nav-link {
      font-size: var(--ostk-text-xs);
    }

    .footer-columns {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--ostk-space-6);
    }
  }
</style>
