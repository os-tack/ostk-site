---
import NavDropdown from '../components/NavDropdown.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ostk — the invisible OS for AI coding agents' } = Astro.props;
const currentPath = Astro.url.pathname;

function buildBreadcrumbs(path: string) {
  const segments = path.split('/').filter(Boolean);
  if (segments.length === 0) return null;

  const labels: Record<string, string> = {
    features: 'Features',
    docs: 'Docs',
    insights: 'Insights',
    legal: 'Legal',
  };

  const items = [{ name: 'Home', url: 'https://ostk.ai/' }];
  let currentPath = '';

  for (let i = 0; i < segments.length; i++) {
    currentPath += '/' + segments[i];
    const name = labels[segments[i]] || segments[i].split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    items.push({ name, url: `https://ostk.ai${currentPath}/` });
  }

  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": items.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.name,
      "item": item.url
    }))
  };
}

const breadcrumbs = buildBreadcrumbs(currentPath);

const featuresItems = [
  { href: '/features/context-injection', label: 'Context Injection' },
  { href: '/features/coordination', label: 'Multi-Agent' },
  { href: '/features/invisible-writes', label: 'Invisible Writes' },
  { href: '/features/audit-trail', label: 'Audit Trail' },
  { href: '/features/tack', label: 'Tack Language' },
  { href: '/features/local-first', label: 'Local-First' },
  { href: '/features/governance', label: 'Governance' },
  { href: '/features/model-switching', label: 'Model Switching' },
  { href: '/features/secret-management', label: 'Secrets' },
  { href: '/features/tui', label: 'TUI' },
];

const docsItems = [
  { href: '/docs/getting-started', label: 'Quick Start' },
  { href: '/docs/commands', label: 'Commands' },
  { href: '/docs/architecture', label: 'Architecture' },
  { href: '/docs/five-laws', label: 'Five Laws' },
  { href: '/docs/humanfile', label: 'HUMANFILE' },
  { href: '/docs/agentfile', label: 'Agentfile' },
  { href: '/docs/downloads', label: 'Downloads' },
];

const directLinks = [
  { href: '/insights', label: 'Insights' },
  { href: 'https://needle-bench.cc', label: 'Bench', external: true },
  { href: '/about', label: 'About' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Canonical -->
  <link rel="canonical" href={`https://ostk.ai${currentPath}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://ostk.ai${currentPath}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://ostk.ai/og-image.png" />
  <meta property="og:site_name" content="ostk" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://ostk.ai/og-image.png" />

  <!-- JSON-LD: Software Application -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ostk",
    "applicationCategory": "DeveloperApplication",
    "description": "The local-first OS for AI agents. Signed, audited, yours.",
    "url": "https://ostk.ai",
    "operatingSystem": "macOS, Linux",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "downloadUrl": "https://github.com/os-tack/ostk.ai/releases",
    "codeRepository": "https://github.com/os-tack/ostk.ai"
  })} />
  {breadcrumbs && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
  )}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <!-- Plausible Analytics — privacy-first, no cookies -->
  <!-- Plausible Analytics — tagged-events variant supports data-analytics attributes + onclick -->
  <script defer data-domain="ostk.ai" src="https://plausible.io/js/script.tagged-events.outbound-links.js"></script>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-os">os</span><span class="logo-diamond">&#9670;</span><span class="logo-tk">tk</span>
      </a>
      <div class="nav-links">
        <NavDropdown label="Features" items={featuresItems} currentPath={currentPath} />
        <NavDropdown label="Docs" items={docsItems} currentPath={currentPath} />
        {directLinks.map(link => (
          link.external ? (
            <a href={link.href} class="nav-link" target="_blank" rel="noopener noreferrer">
              {link.label}<span class="external-icon">↗</span>
            </a>
          ) : (
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
            >
              {link.label}
            </a>
          )
        ))}
        <a href="https://github.com/os-tack" class="nav-link" target="_blank" rel="noopener noreferrer">
          GitHub<span class="external-icon">↗</span>
        </a>
      </div>
    </div>
  </nav>

  <main class="page-content">
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-columns">
        <div class="footer-col">
          <h4 class="footer-col-title">Features</h4>
          <a href="/features/context-injection">Context Injection</a>
          <a href="/features/coordination">Multi-Agent</a>
          <a href="/features/invisible-writes">Invisible Writes</a>
          <a href="/features/audit-trail">Audit Trail</a>
          <a href="/features/tack">Tack Language</a>
          <a href="/features/local-first">Local-First</a>
          <a href="/features/governance">Governance</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Docs</h4>
          <a href="/docs/getting-started">Quick Start</a>
          <a href="/docs/commands">Commands</a>
          <a href="/docs/humanfile">HUMANFILE</a>
          <a href="/docs/agentfile">Agentfile</a>
          <a href="/docs/downloads">Downloads</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Insights</h4>
          <a href="/insights/context-injection">Context Injection</a>
          <a href="/insights/claude-code-source">Claude Code Source</a>
          <a href="/insights/compounding">Compounding</a>
          <a href="/insights/local-first">Local-First</a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Meta</h4>
          <a href="/about">About</a>
          <a href="/security">Security</a>
          <a href="/legal/terms">Terms</a>
          <a href="/legal/privacy">Privacy</a>
          <a href="/legal/license">License</a>
          <a href="https://github.com/os-tack">GitHub</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="logo-os">os</span><span class="logo-diamond">&#9670;</span><span class="logo-tk">tk</span>
        <span class="footer-tagline">the invisible os</span>
      </div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .nav {
    background: var(--ostk-bg-base);
    border-bottom: 1px solid var(--ostk-border-subtle);
    position: sticky;
    top: 0;
    z-index: var(--ostk-z-sticky);
  }

  .nav-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 var(--ostk-space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .nav-logo {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-md);
    font-weight: var(--ostk-weight-bold);
    text-decoration: none;
    color: var(--ostk-text-primary);
  }

  .logo-os, .logo-tk {
    color: var(--ostk-text-primary);
  }

  .logo-diamond {
    color: var(--ostk-needle);
  }

  .nav-links {
    display: flex;
    gap: var(--ostk-space-6);
  }

  .nav-link {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-xs);
    color: var(--ostk-text-secondary);
    text-decoration: none;
    padding: var(--ostk-space-1) 0;
  }

  .nav-link:hover {
    color: var(--ostk-text-primary);
  }

  .nav-link.active {
    color: var(--ostk-text-primary);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .external-icon {
    font-size: 0.7em;
    margin-left: 0.2em;
    opacity: 0.6;
  }

  .footer {
    border-top: 1px solid var(--ostk-border-subtle);
    padding: var(--ostk-space-12) 0 var(--ostk-space-8);
    margin-top: auto;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--ostk-space-8);
    margin-bottom: var(--ostk-space-8);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--ostk-space-2);
  }

  .footer-col-title {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-xs);
    text-transform: uppercase;
    letter-spacing: var(--ostk-tracking-wide);
    color: var(--ostk-text-muted);
    margin-bottom: var(--ostk-space-2);
  }

  .footer-col a {
    font-size: var(--ostk-text-sm);
    color: var(--ostk-text-secondary);
    text-decoration: none;
    transition: color var(--ostk-duration-fast) var(--ostk-easing);
  }

  .footer-col a:hover {
    color: var(--ostk-text-primary);
  }

  .footer-bottom {
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-sm);
    font-weight: var(--ostk-weight-bold);
    border-top: 1px solid var(--ostk-border-subtle);
    padding-top: var(--ostk-space-6);
  }

  .footer-tagline {
    color: var(--ostk-text-muted);
    font-weight: var(--ostk-weight-normal);
    margin-left: var(--ostk-space-3);
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: var(--ostk-space-3);
    }

    .nav-link {
      font-size: var(--ostk-text-xs);
    }

    .footer-columns {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--ostk-space-6);
    }
  }
</style>
