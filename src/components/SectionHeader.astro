---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
}

const { badge, title, subtitle } = Astro.props;
---

<header class="section-header">
  {badge && <span class="section-badge">{badge}</span>}
  <h2 class="section-title">{title}</h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
</header>

<style>
  .section-header {
    margin-bottom: var(--ostk-space-6);
  }

  .section-badge {
    display: inline-block;
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-xs);
    text-transform: uppercase;
    letter-spacing: var(--ostk-tracking-wide);
    color: var(--ostk-needle);
    margin-bottom: var(--ostk-space-2);
  }

  .section-title {
    margin-top: 0;
    margin-bottom: var(--ostk-space-2);
  }

  .section-subtitle {
    font-size: var(--ostk-text-md);
    color: var(--ostk-text-secondary);
    margin-bottom: 0;
    max-width: 40rem;
  }
</style>
