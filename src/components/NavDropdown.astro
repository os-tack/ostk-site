---
interface NavItem {
  href: string;
  label: string;
  external?: boolean;
}

interface Props {
  label: string;
  items: NavItem[];
  currentPath: string;
}

const { label, items, currentPath } = Astro.props;

function isActive(href: string): boolean {
  const norm = currentPath.replace(/\/$/, '');
  return norm === href || norm.startsWith(href + '/');
}

const groupActive = items.some(item => isActive(item.href));
---

<div class="nav-dropdown">
  <button
    class:list={['nav-dropdown-trigger', { active: groupActive }]}
    aria-expanded="false"
    type="button"
  >
    {label}
    <svg class="nav-caret" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M2.5 4l2.5 2.5L7.5 4" />
    </svg>
  </button>
  <div class="nav-dropdown-menu" role="menu">
    {items.map(item => (
      <a
        href={item.href}
        class:list={['nav-dropdown-item', { active: isActive(item.href) }]}
        role="menuitem"
        target={item.external ? '_blank' : undefined}
        rel={item.external ? 'noopener noreferrer' : undefined}
      >
        {item.label}
        {item.external && <span class="external-icon" aria-label="(external)">&#x2197;</span>}
      </a>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('.nav-dropdown').forEach(dropdown => {
    const trigger = dropdown.querySelector('.nav-dropdown-trigger') as HTMLButtonElement;
    const menu = dropdown.querySelector('.nav-dropdown-menu') as HTMLElement;

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      // Close all other dropdowns
      document.querySelectorAll('.nav-dropdown-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
      });
      trigger.setAttribute('aria-expanded', String(!expanded));
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('.nav-dropdown-trigger').forEach(t => {
      t.setAttribute('aria-expanded', 'false');
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.nav-dropdown-trigger').forEach(t => {
        t.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>

<style>
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    background: none;
    border: none;
    color: var(--ostk-text-secondary);
    font-family: var(--ostk-font-mono);
    font-size: var(--ostk-text-xs);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--ostk-space-1);
    padding: var(--ostk-space-1) 0;
    transition: color var(--ostk-duration-fast) var(--ostk-easing);
  }

  .nav-dropdown-trigger:hover,
  .nav-dropdown-trigger.active {
    color: var(--ostk-text-primary);
  }

  .nav-dropdown-trigger.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .nav-caret {
    transition: transform var(--ostk-duration-fast) var(--ostk-easing);
  }

  .nav-dropdown-trigger[aria-expanded="true"] .nav-caret {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + var(--ostk-space-2));
    left: 50%;
    transform: translateX(-50%);
    background: var(--ostk-bg-elevated);
    border: 1px solid var(--ostk-border-default);
    border-radius: var(--ostk-radius-md);
    padding: var(--ostk-space-2) 0;
    min-width: 12rem;
    z-index: var(--ostk-z-dropdown);
    box-shadow: var(--ostk-shadow-md);
  }

  .nav-dropdown-trigger[aria-expanded="true"] + .nav-dropdown-menu {
    display: block;
  }

  .nav-dropdown-item {
    display: block;
    padding: var(--ostk-space-2) var(--ostk-space-4);
    font-size: var(--ostk-text-sm);
    color: var(--ostk-text-secondary);
    text-decoration: none;
    white-space: nowrap;
    transition: background var(--ostk-duration-fast) var(--ostk-easing),
                color var(--ostk-duration-fast) var(--ostk-easing);
  }

  .nav-dropdown-item:hover {
    background: var(--ostk-bg-raised);
    color: var(--ostk-text-primary);
  }

  .nav-dropdown-item.active {
    color: var(--ostk-needle);
  }

  .external-icon {
    font-size: 0.7em;
    margin-left: var(--ostk-space-1);
    opacity: 0.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-caret {
      transition: none;
    }
  }
</style>
