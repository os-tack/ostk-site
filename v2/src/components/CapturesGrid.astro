---
import Terminal from './Terminal.astro';
import captureClock from '../data/captures/clock.txt?raw';
import captureMetrics from '../data/captures/metrics.txt?raw';
import captureInspect from '../data/captures/inspect.txt?raw';
import captureComposition from '../data/captures/composition.txt?raw';

const cards = [
  {
    command: '$ ostk os clock',
    label: 'OSTK_OS_CLOCK',
    body: captureClock,
    caption: 'Your kernel has a clock. Session, swap state, audit events, focus.',
  },
  {
    command: '$ ostk os metrics',
    label: 'OSTK_OS_METRICS',
    body: captureMetrics,
    caption: 'Your kernel keeps the books. Cache hit rate, squash savings, billed tokens — measured per session.',
  },
  {
    command: '$ ostk inspect platform',
    label: 'OSTK_INSPECT_PLATFORM',
    body: captureInspect,
    caption: 'Your kernel knows where it lives. Unix sockets, signals, daemon, gate audit.',
  },
  {
    command: '$ ostk show composition',
    label: 'OSTK_SHOW_COMPOSITION',
    body: captureComposition,
    caption: 'Your kernel meters its own overhead. Per-category, signed at every step.',
  },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  {cards.map((card) => (
    <div class="flex flex-col gap-3">
      <div class="font-body text-[11px] md:text-xs text-primary">
        <span aria-hidden="true">{card.command}</span>
      </div>
      <Terminal label={card.label}>
        <pre class="m-0 p-0 whitespace-pre font-body text-[11px] md:text-xs leading-relaxed text-on-surface">{card.body}</pre>
      </Terminal>
      <p class="font-body text-sm text-secondary leading-relaxed">{card.caption}</p>
    </div>
  ))}
</div>
