// Map Material Symbols names to our Lucide names
const materialToLucide: Record<string, string> = {
  'terminal': 'terminal',
  'code': 'code',
  'download': 'download',
  'rocket_launch': 'rocket',
  'memory': 'cpu',
  'architecture': 'network',
  'hub': 'network',
  'compress': 'minimize',
  'swap_horiz': 'arrow-left-right',
  'tv': 'monitor',
  'person': 'user',
  'smart_toy': 'bot',
  'groups': 'users',
  'settings': 'settings',
  'tune': 'sliders',
  'key': 'key',
  'pin_drop': 'map-pin',
  'gavel': 'gavel',
  'shield': 'shield',
  'verified': 'verified',
  'warning': 'alert-triangle',
  'menu_book': 'book',
  'list_alt': 'list',
  'help': 'help-circle',
  'apps': 'layout-grid',
  'chevron_right': 'chevron-right',
  'auto_fix_high': 'sparkles',
  'edit_off': 'pen-off',
  'edit': 'hard-drive',
  'merge': 'git-merge',
  'translate': 'languages',
  'home': 'home',
  'search': 'search',
  'info': 'help-circle',
  'github': 'github',
  'discord': 'message-circle',
};

const lucideName = materialToLucide[name] || name;
const svgContent = icons[lucideName] || icons['help-circle'];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={svgContent}
/>
