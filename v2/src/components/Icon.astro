---
/**
 * Inline SVG icon component — replaces Material Symbols font (~300KB).
 * Icons from Lucide (https://lucide.dev), MIT licensed.
 * All icons render at 1em by default, inheriting text color.
 */
interface Props {
  name: string;
  class?: string;
  size?: string;
}

const { name, class: className = '', size = '1em' } = Astro.props;

// Lucide SVG paths (24x24 viewBox, stroke-based)
const icons: Record<string, string> = {
