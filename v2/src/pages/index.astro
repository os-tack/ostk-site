---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import Sidebar from '../components/Sidebar.astro';
import Terminal from '../components/Terminal.astro';
import LiveDemos from '../components/LiveDemos.astro';
import { LATEST_TAG } from '../site-version';

const sidebarGroups = {
  items: [
    { icon: 'help_outline', label: 'WHY_OSTK', href: '/why/' },
    { icon: 'rocket_launch', label: 'START_HERE', href: '/start/' },
    { icon: 'extension', label: 'MCP', href: '/docs/mcp/' },
    { icon: 'memory', label: 'KERNEL_SPEC', href: '/docs/kernel-spec/' },
    { icon: 'shield', label: 'TRUST_MODEL', href: '/docs/trust-model/' },
    { icon: 'gavel', label: 'FIVE_LAWS', href: '/docs/five-laws/' },
  ],
  bottomItems: [
    { icon: 'menu_book', label: 'ALL_DOCS', href: '/docs/' },
    { icon: 'code', label: 'SOURCE', href: 'https://github.com/os-tack/ostk.ai' },
  ],
};
---

<Base title="ostk — like containers, for AI agents" description="Run multiple AI coding agents on your codebase. ostk coordinates their writes, bounds what they can touch, and signs the audit trail. One Rust binary, local-first, zero dependencies.">
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://ostk.ai/#organization",
        "name": "ostk",
        "url": "https://ostk.ai",
        "logo": "https://ostk.ai/og-image.png",
        "sameAs": [
          "https://github.com/os-tack",
          "https://discord.gg/ZP6zRp2eF4"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://ostk.ai/#website",
        "name": "ostk",
        "url": "https://ostk.ai",
        "publisher": { "@id": "https://ostk.ai/#organization" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://ostk.ai/?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "SoftwareApplication",
        "name": "ostk",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "macOS, Linux",
        "description": "A local-first kernel for AI coding agents. Coordinates writes, bounds capability, signs audit trails. Like containers, for agents.",
        "url": "https://ostk.ai",
        "downloadUrl": "https://ostk.ai/install.sh",
        "softwareVersion": LATEST_TAG.replace(/^v/, ''),
        "license": "https://ostk.ai/legal/license",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "publisher": { "@id": "https://ostk.ai/#organization" }
      }
    ]
  })} />
  <Sidebar title="OSTK" subtitle={`${LATEST_TAG} STABLE`} groups={sidebarGroups} />

  <main id="main-content" class="flex-1 md:ml-64 pt-16 pb-12 px-4 md:px-10">
    <div class="max-w-5xl mx-auto py-12">

      <!-- Hero A/B test: both variants render in the same HTML. The inline script
           in Base.astro sets `data-hero-variant` on <html> before paint, and CSS
           hides the non-selected variant. SSR fallback (no attribute) shows A. -->

      <!-- Variant A — declarative prose hero (default / SSR / bots / cold loads) -->
      <section data-hero="A" class="mb-12">
        <div class="section-label mb-4">SYSTEM_MANIFEST // OSTK</div>
        <h1 class="serif-text text-7xl font-bold tracking-tighter text-on-surface mb-4">
          ostk
        </h1>
        <p class="font-headline text-xl text-on-surface-variant italic leading-relaxed max-w-2xl mb-6">
          A kernel for AI coding agents.
        </p>
        <p class="font-body text-base text-on-surface max-w-2xl mb-8 leading-relaxed">
          Every syscall returns wrapped in a state envelope — fleet, files, audit, working memory — so your agents stay oriented across thousands of turns. Local-first. One Rust binary.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 max-w-3xl mb-4">
          <button
            type="button"
            data-copy="curl -fsSL https://ostk.ai/install.sh | sh"
            class="plausible-event-name=Install+Copied plausible-event-source=hero plausible-event-variant=A bg-surface-container-lowest border border-surface-variant px-4 py-3 font-body text-sm text-left hover:bg-surface-container-low transition-colors cursor-pointer flex-1"
          >
            <span class="text-outline select-none">install → </span><span class="text-primary">curl -fsSL https://ostk.ai/install.sh | sh</span>
          </button>
          <a
            href="/docs/architecture/"
            class="plausible-event-name=Architecture+View plausible-event-variant=A bg-surface-variant text-primary font-body text-sm py-3 px-6 transition-none hover:bg-surface-container-high flex items-center justify-center gap-2 whitespace-nowrap"
          >
            read the architecture →
          </a>
        </div>
        <p class="font-body text-[10px] text-outline mb-2">macOS (universal arm64+x86_64), Linux musl arm64/x86_64, Windows x86_64. All <a href="https://github.com/os-tack/ostk.ai/releases/latest" class="plausible-event-name=Releases+View underline hover:text-primary">on releases</a>, GPG-signed. ~30 seconds.</p>
      </section>

      <!-- Variant B — show-don't-tell terminal envelope hero (SSR/SSG default) -->
      <section data-hero="B" class="mb-12">
        <div class="section-label mb-4">SYSTEM_MANIFEST // OSTK</div>
        <Terminal label="ostk init">
<pre class="whitespace-pre font-body leading-relaxed m-0"><span class="text-outline select-none">$ </span><span class="text-primary">ostk init</span>
<span class="text-outline">+ exit:0 1.2s</span>

  <span class="text-on-surface">ostk: kernel installed</span>
  <span class="text-on-surface">identity: bound (T2 author)</span>
  <span class="text-on-surface">trust: web-of-trust verified</span>

<span class="text-secondary">[procs]</span>   count:3 active:1 stale:2 dead:0
<span class="text-secondary">[files]</span>   gen_table indexed: 12 files
<span class="text-secondary">[audit]</span>   +5 rows | needles:0 | fleet:1/1
<span class="text-secondary">[loadavg]</span> needles: 0 open | nudges: 0
<span class="text-secondary">[ctx]</span>     <h1 class="text-on-surface font-bold inline m-0 p-0 text-inherit"># ostk</h1>
          <span class="text-on-surface">A kernel for AI coding agents that keeps the frame.</span>
          <span class="text-on-surface">Every syscall returns wrapped — fleet, files, audit, working</span>
          <span class="text-on-surface">memory — so your agents stay oriented. Local-first. One Rust binary.</span>

<button
  type="button"
  data-copy="curl -fsSL https://ostk.ai/install.sh | sh"
  class="plausible-event-name=Install+Copied plausible-event-source=hero plausible-event-variant=B block w-full text-left hover:bg-surface-container-low transition-colors cursor-pointer py-1"
><span class="text-primary">→ get started:</span>  <span class="text-outline select-none">$ </span><span class="text-on-surface">curl -fsSL https://ostk.ai/install.sh | sh</span></button><a
  href="/docs/architecture/"
  class="plausible-event-name=Architecture+View plausible-event-variant=B block hover:bg-surface-container-low transition-colors py-1"
><span class="text-primary">→ tear it apart:</span>  <span class="text-on-surface underline">/docs/architecture/</span></a></pre>
        </Terminal>
      </section>

      <!-- Platform availability + status ribbon (kept; the hero terminal doesn't show this) -->
      <section class="mb-12">
        <p class="font-body text-[10px] text-outline mb-3 max-w-2xl">macOS (universal arm64+x86_64; arm64+macFUSE variant separate), Linux musl arm64/x86_64, Windows x86_64 zip. All <a href="https://github.com/os-tack/ostk.ai/releases/latest" class="plausible-event-name=Releases+View underline hover:text-primary">on releases</a>, GPG-signed. ~30 seconds.</p>

        <!-- Status ribbon -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 py-2 border-y border-surface-variant text-xs">
          <div class="flex gap-2">
            <span class="font-label text-[10px] text-secondary">BINARY:</span>
            <span class="font-label text-[10px] text-on-surface">ONE_RUST_EXECUTABLE</span>
          </div>
          <div class="flex gap-2 md:border-l md:border-surface-variant md:pl-4">
            <span class="font-label text-[10px] text-secondary">DEPS:</span>
            <span class="font-label text-[10px] text-on-surface">NONE_AT_RUNTIME</span>
          </div>
          <div class="flex gap-2 md:border-l md:border-surface-variant md:pl-4">
            <span class="font-label text-[10px] text-secondary">RUNTIME:</span>
            <span class="font-label text-[10px] text-on-surface">LOCAL_ONLY</span>
          </div>
          <div class="flex gap-2 md:border-l md:border-surface-variant md:pl-4">
            <span class="font-label text-[10px] text-secondary">TRUST:</span>
            <span class="font-label text-[10px] text-primary">GPG_SIGNED</span>
          </div>
        </div>
      </section>

      <!-- Where ostk fits in the agent stack -->
      <section class="mb-20">
        <div class="section-label mb-4">WHERE_OSTK_FITS</div>
        <p class="serif-text text-2xl md:text-3xl font-medium text-on-surface leading-snug max-w-3xl mb-10">
          ostk is one layer down from the AI coding tools you already use.
        </p>

        {/* Stacked-layer diagram. Each row: label column (left) + content column (right).
            Mobile stacks the label above the content; desktop renders horizontal rows.
            Vertical arrows connect rows on both axes. */}
        <div class="max-w-3xl">
          {[
            {
              label: 'AGENT_SURFACES',
              body: 'Cursor · Claude Code · Continue · Aider · your CLI · local models (Ollama, MLX)',
            },
            {
              label: 'KERNEL',
              body: 'ostk: state envelope · CAS writes · audit chain · capability pins · identity · fleet coordination',
              emphasis: true,
            },
            {
              label: 'SUBSTRATE',
              body: 'your codebase · your filesystem · your machine',
            },
          ].map((row, idx, arr) => (
            <>
              <div class:list={[
                'grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-6 py-4',
                row.emphasis ? 'bg-surface-container border-l-2 border-primary px-4' : 'bg-surface-container-low px-4',
              ]}>
                <div class="md:col-span-3 flex items-center">
                  <span class={row.emphasis
                    ? 'font-label text-[11px] tracking-widest uppercase text-primary'
                    : 'font-label text-[11px] tracking-widest uppercase text-secondary opacity-70'}>{row.label}</span>
                </div>
                <div class="md:col-span-9 flex items-center">
                  <p class="font-body text-sm text-on-surface leading-relaxed">{row.body}</p>
                </div>
              </div>
              {idx < arr.length - 1 && (
                <div class="flex items-center justify-center py-1" aria-hidden="true">
                  <span class="font-body text-base text-outline">↓</span>
                </div>
              )}
            </>
          ))}
        </div>

        <p class="font-body text-sm text-secondary leading-relaxed max-w-2xl mt-8 mb-8">
          The agent surface is what you type into. The kernel is what keeps multiple of them from stepping on each other, what signs every action, and what ensures your agents stay oriented across thousands of turns. ostk doesn't replace your editor or your model. It sits underneath them.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 max-w-2xl">
          <a
            href="/docs/mcp/"
            class="plausible-event-name=Where+Fits+CTA plausible-event-target=mcp bg-surface-variant text-primary font-body text-sm py-3 px-5 transition-none hover:bg-surface-container-high flex items-center justify-center gap-2 whitespace-nowrap flex-1"
          >
            compose with Claude Code, Cursor, or MCP →
          </a>
          <a
            href="/docs/architecture/"
            class="plausible-event-name=Where+Fits+CTA plausible-event-target=architecture bg-surface-variant text-primary font-body text-sm py-3 px-5 transition-none hover:bg-surface-container-high flex items-center justify-center gap-2 whitespace-nowrap flex-1"
          >
            read the architecture →
          </a>
        </div>
      </section>

      <!-- Live-typed demo videos from real ostk sessions -->
      <section class="mb-20">
        <div class="section-label mb-4">WHAT_THE_KERNEL_LOOKS_LIKE</div>
        <h2 class="serif-text text-2xl md:text-3xl font-medium text-on-surface leading-snug max-w-3xl mb-10">
          Real ostk sessions, live-typed and on-device. Not screenshots. Not reenactments.
        </h2>
        <LiveDemos />
      </section>

      <!-- Three failure modes the kernel addresses -->
      <section class="mb-20">
        <div class="section-label mb-4">HOW_THE_KERNEL_KEEPS_THE_FRAME</div>
        <p class="font-body text-sm text-secondary max-w-2xl mb-8">
          Three failure modes show up the moment LLM agents touch real codebases. ostk addresses each one structurally — at the kernel layer, in the envelope you saw above — not as application-layer hacks bolted onto a chat loop.
        </p>
        <div class="space-y-px">
          {[
            {
              num: '01',
              title: 'They collide.',
              body: 'Two agents edit the same file. Last write wins. Silently. Kernel-mediated CAS writes catch every conflict before it lands. Nothing disappears; the second writer sees a clean error.',
              link: '/why/#collision',
              link_label: 'Read why',
            },
            {
              num: '02',
              title: 'They drift.',
              body: 'Each agent has its own context. They re-discover the same things. They forget what was decided. Every syscall returns the working state envelope, so the agent re-grounds each turn — the project develops a memory the fleet shares.',
              link: '/why/#drift',
              link_label: 'Read why',
            },
            {
              num: '03',
              title: 'They leave no trace.',
              body: 'You can\'t replay, audit, or prove what shipped. The kernel records every action in an append-only, hash-chained, Ed25519-signed audit trail. Replay any session, byte for byte.',
              link: '/why/#trace',
              link_label: 'Read why',
            },
          ].map(problem => (
            <div class="bg-surface-container grid grid-cols-1 md:grid-cols-12 gap-0">
              <div class="md:col-span-1 bg-surface-container-low flex items-center justify-center py-8">
                <span class="serif-text text-3xl font-bold text-primary">{problem.num}</span>
              </div>
              <div class="md:col-span-11 p-6">
                <h3 class="serif-text text-xl font-medium text-on-surface mb-2">{problem.title}</h3>
                <p class="font-body text-xs text-secondary leading-relaxed max-w-xl mb-2">{problem.body}</p>
                <a href={problem.link} class="font-body text-[11px] text-primary hover:underline">→ {problem.link_label}</a>
              </div>
            </div>
          ))}
        </div>
        <p class="font-body text-[11px] text-outline mt-6 max-w-xl">
          Want the substrate spec underneath all of this? <a href="/docs/spec/" class="text-primary hover:underline">Read the canonical specifications →</a>
        </p>
      </section>

      <!-- Why containers comparison -->
      <section class="mb-20">
        <div class="section-label mb-4">CONTAINERS_VS_OSTK</div>
        <p class="font-body text-sm text-secondary max-w-2xl mb-6">
          Containers gave processes isolation. They didn't ship coordination. ostk does.
        </p>
        <div class="bg-surface-container-low p-6 max-w-3xl overflow-x-auto">
          <div class="min-w-[480px]">
          <div class="grid grid-cols-3 gap-4 font-body text-xs border-b border-surface-variant pb-3 mb-3">
            <div class="font-label text-[10px] text-secondary">PROBLEM</div>
            <div class="font-label text-[10px] text-secondary">CONTAINERS</div>
            <div class="font-label text-[10px] text-primary">OSTK</div>
          </div>
          {[
            ['Isolation', 'cgroups + namespaces', 'Capability pins + scoped agent stacks'],
            ['Packaging', 'OCI image', 'Agentfile + signed release package'],
            ['Coordination across instances', 'Bolt-on (Kubernetes, etc.)', 'Built into the kernel'],
            ['Audit of actions', 'Out of band', 'Hash-chained event log per project'],
            ['Identity & trust', 'Image signing (sigstore, etc.)', 'GPG web of trust, four signing tiers'],
            ['Reproducibility', 'Image digest', 'journal.jsonl replay + signed claims'],
            ['Resource bounds', 'CPU/memory limits', 'Token/turn budgets per agent'],
          ].map(row => (
            <div class="grid grid-cols-3 gap-4 font-body text-xs py-2 border-b border-surface-variant">
              <div class="text-secondary">{row[0]}</div>
              <div class="text-on-surface">{row[1]}</div>
              <div class="text-on-surface">{row[2]}</div>
            </div>
          ))}
          </div>
        </div>
        <p class="font-body text-[11px] text-outline mt-3 max-w-xl">
          Not a wrapper around containers. Containers contain processes; ostk contains agents.
        </p>
      </section>

      <!-- What you get -->
      <section class="mb-20">
        <div class="section-label mb-4">WHAT_YOU_GET</div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-surface-variant">
          {[
            { icon: 'merge', label: 'NO_LOST_WRITES', desc: 'Compare-and-swap file edits. Conflicts surface; silent overwrites don\'t happen.' },
            { icon: 'list_alt', label: 'EVERY_ACTION_AUDITED', desc: 'Append-only events, hash-chained, Ed25519-signed. Replay any session.' },
            { icon: 'shield', label: 'CAPABILITY_BOUNDS', desc: 'Capability pins deny by default. Agents that try to escape get a hard no, logged.' },
            { icon: 'key', label: 'NO_KEYS_IN_CONTEXT', desc: 'API keys resolved from keychain at call time. Never in the agent\'s prompt.' },
            { icon: 'compress', label: 'SHARED_CACHE', desc: 'Prompt cache shared across the fleet. One fetch, many agents.' },
            { icon: 'home', label: 'LOCAL_FIRST', desc: 'No cloud sync, no telemetry. Works offline. Your code stays on your machine.' },
          ].map(feature => (
            <div class="bg-surface p-5">
              <div class="flex items-start gap-3">
                <Icon name={feature.icon} size="14" class="text-outline mt-0.5" />
                <div>
                  <div class="font-label text-[10px] text-primary mb-1">{feature.label}</div>
                  <div class="font-body text-xs text-secondary leading-relaxed">{feature.desc}</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/start/" class="plausible-event-name=Start+Here plausible-event-source=footer-cta bg-primary text-on-primary font-body text-sm py-3 px-6 transition-none hover:bg-primary-container flex items-center gap-2">
            <Icon name="rocket_launch" size="14" />
            START_HERE
          </a>
          <a href="https://github.com/os-tack/ostk.ai" class="plausible-event-name=Source+View bg-surface-variant text-primary font-body text-sm py-3 px-6 transition-none hover:bg-surface-container-high flex items-center gap-2">
            <Icon name="code" size="14" />
            VIEW_SOURCE
          </a>
        </div>
      </section>

    </div>
  </main>
</Base>
