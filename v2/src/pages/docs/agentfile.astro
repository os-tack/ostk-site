---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Icon from '../../components/Icon.astro';
import Terminal from '../../components/Terminal.astro';

const directives = [
  { name: 'FROM', req: true, desc: 'Model name. Exactly one required.', example: 'FROM claude-sonnet-4-6' },
  { name: 'PROMPT', req: true, desc: 'System prompt. Inline quoted, unquoted multi-line, file:// reference, or heredoc.', example: 'PROMPT "You are a bug fixer."' },
  { name: 'TOOL', req: false, desc: 'MCP tool name or capability pattern. Aliases: shell, bash → shell; file:read, fs_read → file:read.', example: 'TOOL shell:write(src/)' },
  { name: 'SKILL', req: false, desc: 'Skill bundle name.', example: 'SKILL tdd' },
  { name: 'LIMIT', req: false, desc: 'Key-value resource constraint. Budget, tokens, turns, wall clock, sandbox, permissions.', example: 'LIMIT budget_usd 5' },
  { name: 'WORK', req: false, desc: 'Needle pull-filter expression. At most one. Defines which needles this agent can execute.', example: 'WORK tags=rust,bugfix priority>=P1' },
  { name: 'INTERRUPT', req: false, desc: 'Event-driven wake trigger. Format: file:<path> or event:<name>.', example: 'INTERRUPT event:hay.filed' },
  { name: 'BOOT', req: false, desc: 'Kernel command to run before PROMPT loads. Supports heredoc.', example: 'BOOT ostk boot' },
  { name: 'PIN', req: false, desc: 'Capability pin name. Activates pin.caps policy checks.', example: 'PIN default' },
  { name: 'ISOLATION', req: false, desc: 'Sandbox tier: none (default), nono (Landlock/Seatbelt), docker, firecracker.', example: 'ISOLATION nono' },
  { name: 'ATTEST', req: false, desc: 'Signing mode: self (Ed25519, default), gpg, sigstore, both.', example: 'ATTEST gpg' },
  { name: 'BETA', req: false, desc: 'Beta feature flag. Valid: context-management, fast-mode, token-counting, code-execution, files-api, extended-cache-ttl, output-128k, context-1m.', example: 'BETA files-api' },
];

const limits = [
  { key: 'budget_usd', desc: 'Spending cap in USD' },
  { key: 'tokens', desc: 'Maximum token count' },
  { key: 'turns', desc: 'Maximum conversation turns' },
  { key: 'wall_clock', desc: 'Timeout in seconds' },
  { key: 'context_pct', desc: 'Context window usage percentage cap' },
  { key: 'permissions', desc: 'governed | supervised | restricted' },
  { key: 'revival_policy', desc: 'revive (default) | reap | ask' },
  { key: 'destructive_ops', desc: 'confirm | deny | allow' },
];
---

<DocsLayout
  title="Agentfile"
  description="The agent process descriptor. Defines model, prompt, tools, limits, isolation, and attestation for each agent."
  sectionLabel="CONFIGURATION // AGENT_DESCRIPTOR"
>
  <p class="font-headline text-lg text-on-surface-variant italic leading-relaxed max-w-xl mb-4">
    The container format for agent definitions. Like a Dockerfile for AI agents.
  </p>
  <p class="font-body text-xs text-outline mb-12">
    Location: <code class="text-primary">./Agentfile</code> (default) or <code class="text-primary">./agents/&lt;name&gt;.af</code> (named)
  </p>

  <!-- Example -->
  <section class="mb-16">
    <h2 class="section-label mb-4">EXAMPLE</h2>
    <Terminal>
      <pre><span class="text-outline"># agents/lint-fix.af</span>

<span class="text-primary">FROM</span> claude-sonnet-4-6

<span class="text-primary">PROMPT</span> You are a code quality agent.
Fix all ESLint warnings in the src/ directory.
Run the linter after each fix to verify.

<span class="text-primary">TOOL</span> shell
<span class="text-primary">TOOL</span> file:read
<span class="text-primary">TOOL</span> file:edit

<span class="text-primary">LIMIT</span> budget_usd 2
<span class="text-primary">LIMIT</span> turns 30
<span class="text-primary">LIMIT</span> wall_clock 600

<span class="text-primary">PIN</span> default
<span class="text-primary">ISOLATION</span> nono
<span class="text-primary">ATTEST</span> self</pre>
    </Terminal>
  </section>

  <!-- Directives -->
  <section class="mb-16">
    <h2 class="section-label mb-4">DIRECTIVES</h2>
    <div class="bg-surface-container-low p-6 border-l-2 border-primary">
      {directives.map(d => (
        <div class="flex gap-4 text-xs font-body py-3 border-b border-surface-variant">
          <code class="text-primary w-24 shrink-0">{d.name}</code>
          <span class={`w-8 shrink-0 ${d.req ? 'text-primary' : 'text-outline'}`}>{d.req ? 'REQ' : '—'}</span>
          <span class="text-secondary flex-1">{d.desc}</span>
          <code class="text-outline shrink-0">{d.example}</code>
        </div>
      ))}
    </div>
  </section>

  <!-- LIMIT keys -->
  <section class="mb-16">
    <h2 class="section-label mb-4">LIMIT_KEYS</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-surface-variant">
      {limits.map(l => (
        <div class="bg-surface-container p-4">
          <code class="font-body text-xs text-primary">{l.key}</code>
          <div class="font-body text-xs text-secondary mt-1">{l.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- File resolution -->
  <section class="mb-16">
    <h2 class="section-label mb-4">FILE_RESOLUTION</h2>
    <p class="font-body text-xs text-secondary mb-4">
      The kernel resolves Agentfiles in this order. First match wins.
    </p>
    <div class="space-y-px">
      {[
        { label: 'Default', paths: ['./Agentfile', '.ostk/scheduler.af (legacy)'] },
        { label: 'Named', paths: ['./agents/<name>.af', './<name>.af', './<name>', '.ostk/<name> (legacy)'] },
      ].map(r => (
        <div class="bg-surface-container grid grid-cols-1 md:grid-cols-12">
          <div class="md:col-span-2 bg-surface-container-low px-4 py-3 font-label text-[10px] text-primary">{r.label}</div>
          <div class="md:col-span-10 px-4 py-3">
            {r.paths.map(p => (
              <div class="font-body text-xs text-secondary py-0.5"><code class="text-on-surface">{p}</code></div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROMPT formats -->
  <section class="mb-16">
    <h2 class="section-label mb-4">PROMPT_FORMATS</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-surface-variant">
      {[
        { format: 'Inline quoted', example: 'PROMPT "You are a helper."' },
        { format: 'Inline multi-line', example: 'PROMPT You are a helper.\nAlways check tests.' },
        { format: 'File reference', example: 'PROMPT file://prompts/system.md' },
        { format: 'Heredoc', example: 'PROMPT<<EOF\n...\nEOF' },
      ].map(f => (
        <div class="bg-surface-container p-4">
          <div class="font-label text-[10px] text-primary mb-1">{f.format}</div>
          <code class="font-body text-xs text-secondary">{f.example}</code>
        </div>
      ))}
    </div>
  </section>

  <div class="metadata-ribbon border-t border-surface-variant">
    <span class="font-label text-[10px] text-secondary mr-4">RELATED:</span>
    <a href="/docs/humanfile"><Icon name="person" size="14" class="align-middle mr-1" />HUMANFILE</a>
    <a href="/docs/pins"><Icon name="pin_drop" size="14" class="align-middle mr-1" />CAPABILITY_PINS</a>
    <a href="/docs/trust-model"><Icon name="shield" size="14" class="align-middle mr-1" />TRUST_MODEL</a>
  </div>
</DocsLayout>
