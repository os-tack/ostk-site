---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Icon from '../../components/Icon.astro';
import Terminal from '../../components/Terminal.astro';
---

<DocsLayout
  title="Bail"
  description="Signed, portable OS bundles. Three modes (public, full, export); Ed25519 manifest signatures with GPG cross-compat; per-file detached signatures throughout."
  sectionLabel="REFERENCE // BAIL_PACKAGES"
>
  <p class="font-headline text-lg text-on-surface-variant italic leading-relaxed max-w-xl mb-12">
    A portable bundle pulled from the stack. Each file inside carries its own detached signature. Move identity and boot state between instances — no shared filesystem, no SSH, no cloud sync.
  </p>

  <!-- What bail is -->
  <section class="mb-16">
    <h2 class="serif-text text-3xl font-medium text-on-surface mb-4">What Bail Is</h2>
    <div class="bg-surface-container-high p-6 border-t-4 border-primary">
      <p class="font-body text-sm text-on-surface mb-3">
        A <span class="text-primary">bail of hay</span> pulled from a haystack — compressed, bundled, ready to move. The kernel is <code class="text-primary">haystack</code>; a bail is what you extract from the stack, wrap up, and send somewhere else.
      </p>
      <p class="font-body text-xs text-secondary">
        Mechanically: a tar.gz archive renamed <code class="text-primary">.bail</code>, containing identity files (<code class="text-primary">.primefile</code>, <code class="text-primary">ENTITYFILE</code>), boot state (<code class="text-primary">.boot/INIT</code>), a signed manifest, and — depending on mode — either encrypted kernel state (<code class="text-primary">os.bin</code>) or selective exported content (needles, decisions, docs). Every signable file has its own detached signature alongside it.
      </p>
    </div>
  </section>

  <!-- Three modes -->
  <section class="mb-16">
    <h2 class="section-label mb-6">THREE_MODES</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-surface-variant">
      <div class="bg-surface-container p-6">
        <div class="font-label text-[10px] text-primary mb-2">PUBLIC_MODE</div>
        <code class="font-body text-xs text-on-surface block mb-3">ostk bail pack --public</code>
        <p class="font-body text-xs text-secondary mb-4">
          Portable public snapshot. Ed25519-signed manifest; any receiver can verify with the sender's public key. No encrypted payload — safe to distribute.
        </p>
        <div class="font-label text-[10px] text-outline mb-2">CONTAINS</div>
        <ul class="font-body text-xs text-secondary space-y-1">
          <li><code class="text-primary">.boot/INIT</code> — tack boot protocol</li>
          <li><code class="text-primary">.primefile</code> — signer + recipient fingerprints</li>
          <li><code class="text-primary">ENTITYFILE</code> — identity chain</li>
          <li><code class="text-primary">transition/</code> — GPG↔Ed25519 bridge docs</li>
        </ul>
      </div>
      <div class="bg-surface-container p-6">
        <div class="font-label text-[10px] text-primary mb-2">FULL_MODE</div>
        <code class="font-body text-xs text-on-surface block mb-3">ostk bail pack</code>
        <p class="font-body text-xs text-secondary mb-4">
          Public contents plus <code class="text-primary">os.bin</code> — encrypted internal kernel state. Requires a 40-char recipient fingerprint in <code class="text-primary">.primefile</code>; without one, pack prints a warning and falls back to public mode. Full-mode unpack is <span class="text-primary">fail-closed</span>: missing signature, missing gpg, or unknown Ed25519 key all refuse to unpack.
        </p>
        <div class="font-label text-[10px] text-outline mb-2">ADDS</div>
        <ul class="font-body text-xs text-secondary space-y-1">
          <li><code class="text-primary">os.bin</code> — encrypted tarball of internal state</li>
        </ul>
      </div>
      <div class="bg-surface-container p-6">
        <div class="font-label text-[10px] text-primary mb-2">EXPORT_MODE</div>
        <code class="font-body text-xs text-on-surface block mb-3">ostk bail pack --export @target</code>
        <p class="font-body text-xs text-secondary mb-4">
          Selective knowledge transfer. Packs needles, decisions, and docs matching an optional query. Receiver merges them with <code class="text-primary">{'[I]'}</code> imported markers. GPG-signed.
        </p>
        <div class="font-label text-[10px] text-outline mb-2">CONTAINS</div>
        <ul class="font-body text-xs text-secondary space-y-1">
          <li><code class="text-primary">needles.jsonl</code> — filed work items</li>
          <li><code class="text-primary">decisions.jsonl</code> — append-only decisions</li>
          <li><code class="text-primary">docs/</code> — selected doc files</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Package format -->
  <section class="mb-16">
    <h2 class="section-label mb-4">PACKAGE_FORMAT</h2>
    <Terminal label="BAIL_LAYOUT (public mode, actual output)">
      <pre><span class="text-primary">ostk.bail/</span>
  <span class="text-on-surface">.boot/INIT</span>                          <span class="text-outline"># bootloader protocol</span>
  <span class="text-on-surface">.primefile</span>                          <span class="text-outline"># signer + recipient fingerprints</span>
  <span class="text-on-surface">.primefile.asc</span>                      <span class="text-outline"># GPG detached sig over .primefile</span>
  <span class="text-on-surface">ENTITYFILE</span>                          <span class="text-outline"># identity chain (signing key → issuer)</span>
  <span class="text-on-surface">transition/</span>                         <span class="text-outline"># GPG↔Ed25519 bridge documents</span>
  <span class="text-on-surface">  transition.json</span>                  <span class="text-outline">#   key rotation manifest</span>
  <span class="text-on-surface">  transition.json.self.sig</span>         <span class="text-outline">#   Ed25519 signature</span>
  <span class="text-on-surface">  transition.json.asc</span>              <span class="text-outline">#   GPG signature (cross-compat)</span>
  <span class="text-on-surface">  sequence</span>                         <span class="text-outline">#   canonical signing order</span>
  <span class="text-on-surface">manifest.json</span>                       <span class="text-outline"># version, created, signer, mode, files list</span>
  <span class="text-on-surface">manifest.json.self.sig</span>              <span class="text-outline"># Ed25519 signature (primary for public/full)</span>
  <span class="text-outline">---- full mode adds: ----</span>
  <span class="text-on-surface">os.bin</span>                              <span class="text-outline"># encrypted internal kernel state</span>
  <span class="text-outline">---- export mode replaces content with: ----</span>
  <span class="text-on-surface">needles.jsonl</span>                       <span class="text-outline"># + needles.jsonl.asc</span>
  <span class="text-on-surface">decisions.jsonl</span>                     <span class="text-outline"># + decisions.jsonl.asc</span>
  <span class="text-on-surface">docs/</span>                               <span class="text-outline"># selected doc files</span>
  <span class="text-on-surface">manifest.json.asc</span>                   <span class="text-outline"># GPG signature (export mode)</span>
  <span class="text-outline">---- optional: ----</span>
  <span class="text-on-surface">manifest.json.sigstore</span>              <span class="text-outline"># Sigstore attestation (--attest)</span></pre>
    </Terminal>
    <p class="font-body text-xs text-secondary mt-4 max-w-lg">
      Packed as a <code class="text-primary">.tar.gz</code> renamed to <code class="text-primary">.bail</code>. Each signable file gets its own detached signature file alongside it, not a single manifest-level signature — so a verifier can selectively check any subset and still trust the rest.
    </p>
  </section>

  <!-- Exclusions -->
  <section class="mb-16">
    <h2 class="section-label mb-4">NEVER_INCLUDED</h2>
    <p class="font-body text-xs text-secondary mb-6 max-w-lg">
      Internal kernel state and secrets are excluded from all bail packages. Private keys never appear in any file, log, or error message.
    </p>
    <div class="bg-surface-container-low p-6 border-l-2 border-error">
      {[
        { file: 'journal.jsonl', reason: 'Internal audit trail' },
        { file: 'sessions/', reason: 'Ephemeral session logs' },
        { file: 'agents.jsonl', reason: 'Runtime agent state' },
        { file: 'hwm.jsonl, hwm.lock', reason: 'High-water mark (runtime)' },
        { file: 'gen_table.jsonl, gen_table.lock', reason: 'OCC generation counters' },
        { file: 'identity_counter, identity.lock', reason: 'Runtime identity counters' },
        { file: 'dispatch.json', reason: 'Kernel dispatch table' },
        { file: '*.secret, secrets/', reason: 'Any secret files or secret directory' },
      ].map(e => (
        <div class="flex gap-6 text-xs font-body py-2 border-b border-surface-variant">
          <code class="text-error w-64 shrink-0">{e.file}</code>
          <span class="text-secondary">{e.reason}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Boot from bail -->
  <section class="mb-16">
    <h2 class="serif-text text-3xl font-medium text-on-surface mb-6">Receive and Unpack</h2>
    <div class="space-y-px">
      {[
        { step: '01', action: 'Receive ostk.bail from another instance (email, scp, signed URL — any transport)' },
        { step: '02', action: 'ostk bail verify ostk.bail — checks every present signature (.self.sig Ed25519, .asc GPG), prints per-sig status' },
        { step: '03', action: 'ostk bail unpack ostk.bail — reads manifest.mode up front, then branches: full mode is fail-closed, public/export is advisory. TOFU-pins the source identity on first use' },
        { step: '04', action: 'Public/full: applies .boot/INIT + .primefile. Export: re-IDs needles into local numbering, appends decisions with imported marker' },
        { step: '05', action: 'ostk boot — reports merged OS state. The source signer is now locked; future bails claiming the same identity must match' },
      ].map(s => (
        <div class="bg-surface-container grid grid-cols-12">
          <div class="md:col-span-1 bg-surface-container-low flex items-center justify-center py-3">
            <span class="serif-text text-lg font-bold text-primary">{s.step}</span>
          </div>
          <div class="md:col-span-11 px-4 py-3 flex items-center">
            <code class="font-body text-xs text-secondary">{s.action}</code>
          </div>
        </div>
      ))}
    </div>
    <p class="font-body text-xs text-secondary mt-4 max-w-lg">
      Verification strictness follows the bail's mode (Option C, landed in haystack commit <code class="text-primary">bf69847</code>). <span class="text-primary">Full-mode unpack is fail-closed</span>: missing signature, missing gpg binary, or an unknown Ed25519 public key all refuse to unpack. Full bails carry encrypted cross-machine state and must verify against a pre-shared key. <span class="text-primary">Public and export mode unpack are advisory</span>: unsigned bails still circulate for development, and TOFU-on-first-use pins the signer. A <em>mismatched</em> signature is fatal in every mode — present-but-invalid is always a tamper signal. Source: <code class="text-primary">src/commands/bail.rs:245-371</code>.
    </p>
  </section>

  <!-- Verification -->
  <section class="mb-16">
    <h2 class="section-label mb-4">VERIFICATION</h2>
    <p class="font-body text-xs text-secondary mb-4 max-w-lg">
      Output captured from <code class="text-primary">ostk 3.0.0</code>. Every signature present in the bail is checked; missing signatures are reported as neutral, not failures.
    </p>
    <Terminal label="PUBLIC_MODE_BAIL (Ed25519 only)">
      <div><span class="text-outline select-none">$ </span><span class="text-primary">ostk bail verify ostk.bail</span></div>
      <div class="text-secondary mt-2">ostk bail verify: /Users/scott/haystack/ostk.bail</div>
      <div class="text-primary">Ed25519: VERIFIED (inline)</div>
      <div class="text-secondary">GPG: no manifest.json.asc in bail</div>
      <div class="text-secondary">  created: 2026-04-11T04:56:41Z</div>
      <div class="text-secondary">  files:   8</div>
    </Terminal>
    <Terminal label="EXPORT_MODE_BAIL (GPG signed)">
      <div><span class="text-outline select-none">$ </span><span class="text-primary">ostk bail verify haystack-export.bail</span></div>
      <div class="text-secondary mt-2">ostk bail verify: /tmp/haystack-export.bail</div>
      <div class="text-primary">GPG: VERIFIED</div>
      <div class="text-secondary">  signer: gpg: Good signature from "Scott Meyer &lt;scott@ostk.ai&gt;" [ultimate]</div>
      <div class="text-secondary">  created: 2026-04-11T04:55:15Z</div>
      <div class="text-secondary">  files:   3</div>
    </Terminal>
    <p class="font-body text-xs text-secondary mt-4 max-w-lg">
      Note: the Ed25519 line reads <code class="text-primary">VERIFIED (inline)</code> because Ed25519 verification happens inside the kernel process — no shell-out to a GPG subprocess. GPG verification calls <code class="text-primary">gpg --verify</code> and quotes its output. Both mechanisms must succeed when both signatures are present.
    </p>
  </section>

  <!-- Commands -->
  <section class="mb-16">
    <h2 class="section-label mb-4">COMMANDS</h2>
    <div class="bg-surface-container-low p-6 border-l-2 border-primary">
      {[
        { cmd: 'ostk bail pack', desc: 'Default: full mode. Includes os.bin if .primefile has a recipient fingerprint; otherwise silently falls back to public mode.' },
        { cmd: 'ostk bail pack --public', desc: 'Public snapshot: .boot/INIT + .primefile + ENTITYFILE + transition/ + manifest. Ed25519-signed. Safe to distribute.' },
        { cmd: 'ostk bail pack --attest', desc: 'Add a Sigstore attestation (manifest.json.sigstore) alongside the primary signature. Combines with any pack mode.' },
        { cmd: 'ostk bail pack --export @identity [--query <term>] [--include needles,decisions,docs] [--out <path>]', desc: 'Export mode: selective knowledge transfer. Packs matching needles, decisions, and/or docs. GPG-signed; receiver merges with [I] imported markers.' },
        { cmd: 'ostk bail unpack <FILE>', desc: 'Verify all present signatures, then merge state. Public/full: apply .boot + .primefile. Export: re-ID needles into local numbering, append decisions as imported.' },
        { cmd: 'ostk bail verify <FILE>', desc: 'Verify without unpacking. Checks every signature (Ed25519 .self.sig + GPG .asc + Sigstore .sigstore); prints per-sig status.' },
      ].map(c => (
        <div class="flex gap-6 text-xs font-body py-3 border-b border-surface-variant">
          <code class="text-primary w-72 shrink-0 font-mono">{c.cmd}</code>
          <span class="text-secondary">{c.desc}</span>
        </div>
      ))}
    </div>
  </section>

  <div class="metadata-ribbon border-t border-surface-variant">
    <span class="font-label text-[10px] text-secondary mr-4">RELATED:</span>
    <a href="/docs/primefile"><Icon name="settings" size="14" class="align-middle mr-1" />PRIMEFILE</a>
    <a href="/docs/trust-model"><Icon name="shield" size="14" class="align-middle mr-1" />TRUST_MODEL</a>
    <a href="/docs/session-topology"><Icon name="hub" size="14" class="align-middle mr-1" />SESSION_TOPOLOGY</a>
    <a href="/governance"><Icon name="gavel" size="14" class="align-middle mr-1" />GOVERNANCE</a>
  </div>
</DocsLayout>
