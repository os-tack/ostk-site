---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Icon from '../../components/Icon.astro';
import Terminal from '../../components/Terminal.astro';
---

<DocsLayout
  title="Secrets"
  description="API key management for ostk: platform keychain storage, BYO secret manager, resolution order, output masking, and zero-context-leak guarantees."
  sectionLabel="CONFIGURATION // SECRET_MGMT"
>
  <p class="font-headline text-lg text-on-surface-variant italic leading-relaxed max-w-xl mb-4">
    Secrets never enter the LLM context. The kernel resolves keys at call time and injects them via subprocess environment variables.
  </p>
  <p class="font-body text-xs text-outline mb-12">
    Authorized keys declared in <code class="text-primary">HUMANFILE SECRET &lt;&lt;KEYS</code> block
  </p>

  <!-- Commands -->
  <section class="mb-16">
    <h2 class="section-label mb-4">COMMANDS</h2>
    <div class="space-y-4">
      <div>
        <Terminal label="SET">
          <div><span class="text-outline select-none">$ </span><span class="text-primary">ostk secret set ANTHROPIC_API_KEY</span></div>
          <div class="text-secondary mt-1">Enter value: ●●●●●●●●</div>
          <div class="text-secondary">✓ stored in macOS Keychain (service: ostk, account: ANTHROPIC_API_KEY)</div>
        </Terminal>
      </div>
      <div>
        <Terminal label="LIST">
          <div><span class="text-outline select-none">$ </span><span class="text-primary">ostk secret list</span></div>
          <div class="text-secondary mt-1">ANTHROPIC_API_KEY    ✓ keychain</div>
          <div class="text-secondary">GEMINI_API_KEY       ✓ keychain</div>
          <div class="text-secondary">OPENROUTER_API_KEY   ✗ not found</div>
        </Terminal>
      </div>
      <div>
        <Terminal label="TEST">
          <div><span class="text-outline select-none">$ </span><span class="text-primary">ostk secret test ANTHROPIC_API_KEY</span></div>
          <div class="text-secondary mt-1">✓ resolves (sk-ant-●●●● 48 chars)</div>
        </Terminal>
      </div>
    </div>
  </section>

  <!-- Resolution order -->
  <section class="mb-16">
    <h2 class="section-label mb-4">RESOLUTION_ORDER</h2>
    <div class="space-y-px">
      {[
        { step: '01', source: 'BYO_SECRET_MANAGER', desc: 'secret_cmd from .ostk/config (e.g. bw, op, pass). Highest priority.', note: 'OSTK_SECRET_CMD env var supported for backward compat' },
        { step: '02', source: 'PLATFORM_KEYCHAIN', desc: 'macOS: security find-generic-password. Linux: secret-tool lookup.', note: 'ostk secret set stores here' },
        { step: '03', source: 'ENVIRONMENT_VARIABLE', desc: 'Fallback to $KEY in shell environment.', note: 'Least secure — visible in process table' },
      ].map(s => (
        <div class="bg-surface-container grid grid-cols-1 md:grid-cols-12">
          <div class="md:col-span-1 bg-surface-container-low flex items-center justify-center py-4">
            <span class="serif-text text-xl font-bold text-primary">{s.step}</span>
          </div>
          <div class="md:col-span-3 px-4 py-4">
            <span class="font-body text-xs text-on-surface font-bold">{s.source}</span>
          </div>
          <div class="md:col-span-5 px-4 py-4">
            <span class="font-body text-xs text-secondary">{s.desc}</span>
          </div>
          <div class="md:col-span-3 px-4 py-4">
            <span class="font-body text-[10px] text-outline">{s.note}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Masking -->
  <section class="mb-16">
    <h2 class="serif-text text-3xl font-medium text-on-surface mb-4">Output Masking</h2>
    <div class="bg-surface-container-high p-6 border-t-4 border-primary">
      <p class="font-body text-xs text-on-surface mb-3">
        All tool output passes through <code class="text-primary">secrets::mask()</code> before the LLM sees it. Secret values are replaced with <code class="text-primary">sk-ant-●●●● (48 chars)</code> format — prefix preserved, length hinted, value hidden.
      </p>
      <p class="font-body text-xs text-secondary">
        Masking covers: Bash output, file reads, error messages, environment dumps. Minimum 8 characters to mask.
      </p>
    </div>
  </section>

  <!-- Known keys -->
  <section class="mb-16">
    <h2 class="section-label mb-4">KNOWN_API_KEYS</h2>
    <div class="bg-surface-container-low p-6 border-l-2 border-primary">
      {[
        { key: 'ANTHROPIC_API_KEY', provider: 'anthropic' },
        { key: 'GEMINI_API_KEY', provider: 'google' },
        { key: 'MISTRAL_API_KEY', provider: 'mistral' },
        { key: 'OPENROUTER_API_KEY', provider: 'openrouter' },
        { key: 'OPENROUTER_MANAGEMENT_KEY', provider: 'openrouter-mgmt' },
        { key: 'OPEN_ROUTER_API_KEY', provider: 'openrouter-alt' },
        { key: 'OPENAI_API_KEY', provider: 'openai' },
        { key: 'MODEL_API_KEY', provider: 'universal' },
      ].map(k => (
        <div class="flex justify-between text-xs font-body py-2 border-b border-surface-variant">
          <code class="text-primary">{k.key}</code>
          <span class="text-outline">{k.provider}</span>
        </div>
      ))}
    </div>
  </section>

  <div class="metadata-ribbon border-t border-surface-variant">
    <span class="font-label text-[10px] text-secondary mr-4">RELATED:</span>
    <a href="/docs/humanfile/"><Icon name="person" size="14" class="align-middle mr-1" />HUMANFILE</a>
    <a href="/docs/trust-model/"><Icon name="shield" size="14" class="align-middle mr-1" />TRUST_MODEL</a>
  </div>
</DocsLayout>
