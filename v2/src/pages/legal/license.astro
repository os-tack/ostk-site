---
import Base from '../../layouts/Base.astro';
---

<Base title="License" description="ostk license terms. Free for personal and internal commercial use. Binary redistribution and reverse engineering prohibited.">
  <main id="main-content" class="pt-16 pb-12 px-10 max-w-3xl mx-auto">
    <div class="py-12">
      <div class="section-label mb-4">LEGAL // LICENSE</div>
      <h1 class="serif-text text-5xl font-bold tracking-tighter text-on-surface mb-8">License</h1>

      <p class="font-body text-sm text-secondary mb-8">Copyright 2026 ostk.ai. All rights reserved.</p>

      <section class="mb-12">
        <h2 class="serif-text text-2xl font-medium text-on-surface mb-4">Grant</h2>
        <p class="font-body text-xs text-secondary mb-4">The ostk binary is provided free of charge for personal and internal commercial use. You may:</p>
        <ul class="font-body text-xs text-secondary space-y-2 list-disc pl-6">
          <li><strong class="text-on-surface">Use</strong> the binary for any purpose — personal projects, company work, research, education</li>
          <li><strong class="text-on-surface">Install</strong> on any number of machines you operate</li>
          <li><strong class="text-on-surface">Run</strong> in CI/CD pipelines and automated workflows</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="serif-text text-2xl font-medium text-on-surface mb-4">Restrictions</h2>
        <p class="font-body text-xs text-secondary mb-4">You may not:</p>
        <ul class="font-body text-xs text-secondary space-y-2 list-disc pl-6">
          <li><strong class="text-on-surface">Redistribute</strong> the binary or any modified version</li>
          <li><strong class="text-on-surface">Reverse engineer, decompile, or disassemble</strong> the binary</li>
          <li><strong class="text-on-surface">Remove or alter</strong> copyright notices, signatures, or attribution</li>
          <li><strong class="text-on-surface">Offer as a service</strong> to third parties</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="serif-text text-2xl font-medium text-on-surface mb-4">Source Code</h2>
        <p class="font-body text-xs text-secondary">Source code is not yet publicly available. An open source release under a dual license is planned.</p>
      </section>

      <section class="mb-12">
        <h2 class="serif-text text-2xl font-medium text-on-surface mb-4">No Warranty</h2>
        <p class="font-body text-[10px] text-outline leading-relaxed uppercase">
          THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED. IN NO EVENT SHALL THE AUTHORS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY.
        </p>
      </section>

      <p class="font-body text-xs text-secondary">
        Questions: <a href="mailto:contact@ostk.ai" class="text-primary hover:underline">contact@ostk.ai</a>
      </p>
    </div>
  </main>
</Base>
