---
import Base from '../layouts/Base.astro';
---

<Base title="404">
  <main id="main-content" class="flex-1 pt-16 pb-12 px-10 flex items-center justify-center min-h-[60vh]">
    <div class="text-center">
      <div class="serif-text text-9xl font-bold text-primary mb-4">404</div>
      <div class="font-label text-xs text-outline uppercase tracking-widest mb-8">PAGE_NOT_FOUND // NULL_REFERENCE</div>
      <p class="font-body text-sm text-secondary mb-8">The requested resource does not exist in this archive.</p>
      <div class="flex gap-4 justify-center">
        <a href="/" class="bg-primary text-on-primary font-body text-xs py-3 px-6 transition-none hover:bg-primary-container">
          ARCHIVE_ROOT
        </a>
        <a href="/docs" class="bg-surface-variant text-primary font-body text-xs py-3 px-6 transition-none hover:bg-surface-container-high">
          DOCUMENTATION
        </a>
      </div>
    </div>
  </main>
</Base>
