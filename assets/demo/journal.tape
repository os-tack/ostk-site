# journal.tape — audit chain integrity check.
# Pre: cd into any ostk-init'd dir with at least one journal row.

Output "/Users/scottmeyer/projects/ostk-site/v2/public/assets/demo/journal.gif"
Output "/Users/scottmeyer/projects/ostk-site/v2/public/assets/demo/journal.mp4"

Set FontFamily "Monaco"
Set FontSize 16
Set Width 1100
Set Height 550
Set Theme "Dracula"
Set Padding 20
Set TypingSpeed 60ms

Sleep 400ms

Type `ostk os journal verify`
Enter
Sleep 3500ms
