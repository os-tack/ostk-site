# clock.tape — the kernel-has-a-clock reveal.
# Pre: cd into any ostk-init'd dir.

Output "/Users/scottmeyer/projects/ostk-site/v2/public/assets/demo/clock.gif"
Output "/Users/scottmeyer/projects/ostk-site/v2/public/assets/demo/clock.mp4"

Set FontFamily "Monaco"
Set FontSize 16
Set Width 1100
Set Height 320
Set Theme "Dracula"
Set Padding 20
Set TypingSpeed 60ms

Sleep 400ms

Type `ostk os clock`
Enter
Sleep 2500ms
