#!/bin/sh
# ostk installer — downloads the latest haystack binary
# Usage: curl -fsSL https://ostk.ai/install | sh
set -e

REPO="os-tack/ostk.ai"
BINARY="haystack"

# Detect platform
OS=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH=$(uname -m)

case "$OS" in
  darwin) PLATFORM="apple-darwin" ;;
  linux)  PLATFORM="unknown-linux-musl" ;;
  *)      echo "Unsupported OS: $OS"; exit 1 ;;
esac

case "$ARCH" in
  x86_64|amd64)  TARGET="x86_64-$PLATFORM" ;;
  aarch64|arm64) TARGET="aarch64-$PLATFORM" ;;
  *)             echo "Unsupported architecture: $ARCH"; exit 1 ;;
esac

# Get latest release
LATEST=$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" | grep '"tag_name"' | head -1 | sed 's/.*"v//' | sed 's/".*//')

if [ -z "$LATEST" ]; then
  echo "No release found. Install from source:"
  echo "  git clone https://github.com/$REPO.git && cd haystack && cargo install --path ."
  exit 1
fi

ASSET="haystack-$TARGET"
URL="https://github.com/$REPO/releases/download/v$LATEST/$ASSET"

echo "Installing haystack v$LATEST ($TARGET)..."

# Download to temp
TMP=$(mktemp -d)
curl -fsSL "$URL" -o "$TMP/$BINARY.tar.gz"

# Extract
tar -xzf "$TMP/$BINARY.tar.gz" -C "$TMP"
chmod +x "$TMP/$BINARY"

# macOS: clear Gatekeeper quarantine flag (cross-compiled binary, not notarized)
if [ "$OS" = "darwin" ]; then
  xattr -rc "$TMP/$BINARY" 2>/dev/null || true
fi

# Install
INSTALL_DIR="${INSTALL_DIR:-$HOME/.local/bin}"
mkdir -p "$INSTALL_DIR"
mv "$TMP/$BINARY" "$INSTALL_DIR/$BINARY"
# Create ostk + hs symlinks — the kernel is invisible, users type ostk
ln -sf "$INSTALL_DIR/$BINARY" "$INSTALL_DIR/ostk"
ln -sf "$INSTALL_DIR/$BINARY" "$INSTALL_DIR/hs"
rm -rf "$TMP"

echo "Installed: $INSTALL_DIR/ostk (+ hs)"
echo ""
echo "Add to PATH if needed:"
echo "  export PATH=\"$INSTALL_DIR:\$PATH\""
echo ""
echo "Get started:"
echo "  cd your-repo"
echo "  ostk install"
echo "  ostk boot"
